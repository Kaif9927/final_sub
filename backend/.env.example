# Copy these into Render (or local backend/.env). Mark secrets in Render: DB_PASSWORD, SESSION_SECRET, MYSQL_SSL_CA_PEM.

NODE_ENV=production

DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database

DB_SSL=1

# TLS — local: path to PEM file
# MYSQL_SSL_CA=C:\path\to\ca-chain.pem

# TLS — Render / cloud: paste full certificate chain (BEGIN/END lines included). Use one line or multiline in dashboard.
# MYSQL_SSL_CA_PEM=

# Only if you cannot verify TLS (insecure): MYSQL_SSL_REJECT_UNAUTHORIZED=0

SESSION_SECRET=generate-a-long-random-string

# Optional CORS: only if browser uses a different origin than this app (comma-separated URLs). Same Render URL = leave unset.
# ALLOWED_ORIGINS=
