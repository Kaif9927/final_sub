# --- PostgreSQL (Render: paste "External Database URL" from your Postgres dashboard) ---
# Either name works (Render Environment sometimes uses DB_URL only).
DATABASE_URL=postgresql://user:password@host.region-postgres.render.com/dbname
# DB_URL=postgresql://user:password@host.region-postgres.render.com/dbname
# Optional: force SSL when not on render.com
# DATABASE_SSL=1

# --- Local / legacy MySQL is no longer used by this branch; use DATABASE_URL + init_pg.sql ---

SESSION_SECRET=change-me

# Optional: browser origins for CORS (comma-separated)
# ALLOWED_ORIGINS=https://acxiom-consulting-private-limited-1.onrender.com
