# MariaDB / MySQL (SkySQL, local, etc.)

# Option A — connection URL (password must be URL-encoded if it has special characters)
# DATABASE_URL=mysql://user:password@host.example.com:4003/your_database

# Option B — discrete variables (good for SkySQL when the password has =, ^, etc.)
DB_HOST=serverless-us-central1.sysp0000.db2.skysql.com
DB_PORT=4003
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database

# SkySQL / TLS: download the certificate authority chain from the service dashboard, then:
# MYSQL_SSL_CA=C:\path\to\Skysql.pem
# If you must test without verifying the server cert (insecure): MYSQL_SSL_REJECT_UNAUTHORIZED=0

# Force SSL without a CA file (less secure than using MYSQL_SSL_CA):
# MYSQL_SSL=1

SESSION_SECRET=change-me

# CORS: required only if the web UI is served from a different origin than this API (different host/port/scheme).
# Comma-separated list; each value is normalized (trailing slashes ignored). Never use * with credentials.
# Local + deployed example:
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.onrender.com
# ALLOWED_ORIGINS=
